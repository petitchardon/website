---
import type { Lang } from '../i18n';
import { getDict, asset } from '../i18n';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackgroundLayers from '../components/BackgroundLayers.astro';
import StructuredData from '../components/StructuredData.astro';

export interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  pathname?: string;
  bodyPage?: string;
  showStructuredData?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  ogType,
  pathname = Astro.url.pathname,
  bodyPage = 'home',
  showStructuredData = false,
  showHeader = true,
  showFooter = true,
  noindex = false,
} = Astro.props;

const dict = getDict(lang);
const htmlLang = lang === 'fr' ? 'fr' : 'en';
---
<!DOCTYPE html>
<html lang={htmlLang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      pathname={pathname}
      lang={lang}
      noindex={noindex}
    />
    <link rel="icon" href={asset('favicon.svg')} type="image/svg+xml" />
    <link rel="manifest" href={asset('site.webmanifest')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={asset('assets/fonts/Roca-Font/Roca%20Black.ttf')} as="font" type="font/ttf" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href={asset('css/style.css')} />
    {showStructuredData && <StructuredData />}
  </head>
  <body data-page={bodyPage}>
    <a class="skip-link" href="#contenu-principal">{dict.common.skipToContent}</a>
    <BackgroundLayers />
    {showHeader && <Header lang={lang} pathname={pathname} />}
    <main id="contenu-principal">
      <slot />
    </main>
    {showFooter && <Footer lang={lang} />}
    <script src={asset('js/main.js')} is:inline defer></script>
  </body>
</html>
