---
import type { Lang } from '../i18n';
import { getDict, asset } from '../i18n';
import '@fontsource-variable/fredoka';
import '@fontsource-variable/raleway';
import '../styles/main.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackgroundLayers from '../components/BackgroundLayers.astro';
import StructuredData from '../components/StructuredData.astro';
import Observability from '../components/Observability.astro';

export interface Props {
  lang: Lang;
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  pathname?: string;
  bodyPage?: string;
  showStructuredData?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  ogType,
  pathname = Astro.url.pathname,
  bodyPage = 'home',
  showStructuredData = false,
  showHeader = true,
  showFooter = true,
  noindex = false,
} = Astro.props;

const dict = getDict(lang);
const htmlLang = lang === 'fr' ? 'fr' : 'en';
---
<!DOCTYPE html>
<html lang={htmlLang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Anti-FOUC: apply the chosen theme before first paint. petitchardon is
      // a dark-first brand, so dark is the default; an explicit user choice
      // (persisted) always wins.
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          document.documentElement.setAttribute(
            'data-theme',
            stored === 'light' || stored === 'dark' ? stored : 'dark'
          );
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <SEO
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      pathname={pathname}
      lang={lang}
      noindex={noindex}
    />
    <link rel="icon" href={asset('favicon.svg')} type="image/svg+xml" />
    <link rel="manifest" href={asset('site.webmanifest')} />
    {showStructuredData && <StructuredData />}
  </head>
  <body data-page={bodyPage}>
    <a class="skip-link" href="#contenu-principal">{dict.common.skipToContent}</a>
    <BackgroundLayers />
    {showHeader && <Header lang={lang} pathname={pathname} />}
    <main id="contenu-principal">
      <slot />
    </main>
    {showFooter && <Footer lang={lang} />}
    <script src={asset('js/main.js')} is:inline defer></script>
    <Observability />
  </body>
</html>
