---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectPage from '../../components/ProjectPage.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return projects.map((project, i) => {
    const next = projects[(i + 1) % projects.length];
    return {
      params: { slug: project.data.slugs.fr },
      props: { project, index: i + 1, next },
    };
  });
}

const { project, index, next } = Astro.props;
const lang = 'fr' as const;
const pathname = `/projects/${project.data.slugs.fr}.html`;
---
<BaseLayout
  lang={lang}
  title={`${project.data.title} — étude de cas | petitchardon`}
  description={project.data.description.fr}
  pathname={pathname}
  bodyPage="project"
>
  <ProjectPage
    lang={lang}
    slug={project.data.slugs.fr}
    projectTitle={project.data.title}
    projectTag={project.data.tag}
    index={index}
    nextSlug={next.data.slugs.fr}
    nextTitle={next.data.title}
  />
</BaseLayout>
