---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDict, homeUrl } from '../i18n';

const lang = 'fr' as const;
const dict = getDict(lang);
const home = homeUrl(lang);
---
<BaseLayout
  lang={lang}
  title={dict.notFound.title}
  description={dict.notFound.description}
  pathname="/404.html"
  bodyPage="not-found"
  showHeader={true}
  showFooter={true}
  noindex={true}
>
  <section class="notfound" data-animate="fade-up">
    <div class="container notfound__inner">
      <p class="salle__label" aria-hidden="true">
        <span class="salle__num">salle 404</span>
        <span class="salle__tick"></span>
        <span class="salle__caption">{dict.galerie.exhibitionLabel}</span>
      </p>
      {/* An empty frame on the wall — the work that isn't here. */}
      <div class="notfound__frame" aria-hidden="true">
        <span class="notfound__frame-num">404</span>
      </div>
      <h1 class="notfound__title">{dict.notFound.h1}</h1>
      <p class="notfound__body">{dict.notFound.body}</p>
      <div class="project-cta__actions notfound__actions">
        <a class="btn btn--primary" href={home}>{dict.notFound.ctaHome}</a>
        <a class="btn btn--ghost" href={`${home}#contact`}>{dict.notFound.ctaContact}</a>
      </div>
    </div>
  </section>
</BaseLayout>
