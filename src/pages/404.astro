---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDict, homeUrl, asset } from '../i18n';

const lang = 'fr' as const;
const dict = getDict(lang);
const home = homeUrl(lang);
---
<BaseLayout
  lang={lang}
  title={dict.notFound.title}
  description={dict.notFound.description}
  pathname="/404.html"
  bodyPage="not-found"
  showHeader={false}
  showFooter={false}
  noindex={true}
>
  <section class="project-hero numero-spread" data-animate="fade-up">
    <span class="riso-marks" aria-hidden="true">
      <span class="riso-mark riso-mark--tl"></span>
      <span class="riso-mark riso-mark--tr"></span>
      <span class="riso-mark riso-mark--bl"></span>
      <span class="riso-mark riso-mark--br"></span>
    </span>
    <div class="container project-hero__inner project-hero__inner--404">
      <div class="project-hero__intro glass-surface">
        <p class="folio">{dict.numero.issue} — 404</p>
        <p class="breadcrumb">404</p>
        <h1>{dict.notFound.h1}</h1>
        <p>{dict.notFound.body}</p>
        <div class="project-cta__actions">
          <a class="btn btn--primary" href={home}>{dict.notFound.ctaHome}</a>
          <a class="btn btn--ghost" href={`${home}#contact`}>{dict.notFound.ctaContact}</a>
        </div>
      </div>
      <figure class="project-hero__visual not-found__plate" aria-hidden="true">
        <img class="riso-art" src={asset('assets/numero/cover-art.svg')} alt="" width="420" height="520" loading="eager" />
      </figure>
    </div>
  </section>
</BaseLayout>
