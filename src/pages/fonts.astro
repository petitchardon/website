---
// Page-panel de comparaison de fontes display (titres).
// Sert uniquement à choisir un remplaçant libre (OFL) de la police Roca d'origine.
// À supprimer une fois la fonte choisie — non destinée à la production.
import '@fontsource-variable/quicksand';
import '@fontsource-variable/comfortaa';
import '@fontsource-variable/nunito';
import '@fontsource-variable/outfit';
import '@fontsource-variable/jost';
import '@fontsource-variable/albert-sans';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/baloo-2/400.css';
import '@fontsource/baloo-2/500.css';
import '@fontsource/baloo-2/600.css';
import '@fontsource/baloo-2/700.css';
import '@fontsource/varela-round/400.css';

type Candidate = {
  id: string;
  name: string;
  family: string;
  note: string;
  variable: boolean;
};

const rounded: Candidate[] = [
  { id: 'quicksand', name: 'Quicksand', family: '"Quicksand Variable"', note: 'Géométrique arrondi, raffiné — le plus proche de Roca', variable: true },
  { id: 'comfortaa', name: 'Comfortaa', family: '"Comfortaa Variable"', note: 'Géométrique très arrondi, doux et aéré', variable: true },
  { id: 'varela', name: 'Varela Round', family: '"Varela Round"', note: 'Arrondi compact et chaleureux (une seule graisse)', variable: false },
  { id: 'nunito', name: 'Nunito', family: '"Nunito Variable"', note: 'Arrondi humaniste, monte en graisse facilement', variable: true },
  { id: 'baloo2', name: 'Baloo 2', family: '"Baloo 2"', note: 'Display arrondi épais — esprit « Roca Black »', variable: false },
];

const geometric: Candidate[] = [
  { id: 'poppins', name: 'Poppins', family: '"Poppins"', note: 'Géométrique net (style Futura), très populaire', variable: false },
  { id: 'jost', name: 'Jost', family: '"Jost Variable"', note: 'Géométrique élégant inspiré de Futura', variable: true },
  { id: 'outfit', name: 'Outfit', family: '"Outfit Variable"', note: 'Géométrique amical et moderne', variable: true },
  { id: 'albert', name: 'Albert Sans', family: '"Albert Sans Variable"', note: 'Géométrique sobre, proportions Avenir', variable: true },
];

const sections = [
  { title: 'Arrondi géométrique — esprit de la police d’origine (Roca)', items: rounded },
  { title: 'Géométrique net — alternative plus sobre / moderne', items: geometric },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel fontes — petit chardon</title>
    <style>
      :root {
        --bg: #fbf7f0;
        --ink: #211f3d;
        --muted: #6c6a85;
        --line: #e6ddcd;
        --accent: #e5447d;
        --card: #ffffff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 980px; margin: 0 auto; padding: 3rem 1.25rem 5rem; }
      .lede h1 { font-size: 1.8rem; margin: 0 0 .4rem; }
      .lede p { color: var(--muted); margin: 0 0 .35rem; max-width: 60ch; line-height: 1.5; }
      .lede code { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: .1em .4em; }
      .section-title {
        font-size: .8rem; letter-spacing: .08em; text-transform: uppercase;
        color: var(--accent); font-weight: 700; margin: 2.8rem 0 1rem;
      }
      .card {
        background: var(--card); border: 1px solid var(--line); border-radius: 18px;
        padding: 1.5rem 1.6rem 1.8rem; margin-bottom: 1.1rem;
      }
      .card__head {
        display: flex; align-items: baseline; gap: .65rem; flex-wrap: wrap;
        border-bottom: 1px dashed var(--line); padding-bottom: .8rem; margin-bottom: 1rem;
      }
      .card__name { font-size: 1.05rem; font-weight: 700; }
      .card__note { color: var(--muted); font-size: .9rem; }
      .card__tag {
        margin-left: auto; font-size: .72rem; color: var(--muted);
        border: 1px solid var(--line); border-radius: 999px; padding: .1rem .55rem;
      }
      .spec { font-family: var(--ff); text-transform: lowercase; color: var(--ink); }
      .brand { font-size: clamp(2.6rem, 7vw, 5rem); line-height: .98; font-weight: 600; margin: .1rem 0 .2rem; }
      .headline { font-size: clamp(1.5rem, 3.4vw, 2.6rem); line-height: 1.06; font-weight: 500; margin: .2rem 0 .55rem; }
      .tagline { font-size: clamp(1rem, 1.8vw, 1.25rem); font-weight: 400; color: var(--muted); }
      .weights { margin-top: .9rem; display: flex; gap: 1.3rem; flex-wrap: wrap; }
      .weights span { font-size: 1.5rem; line-height: 1; }
      .weights small { display: block; font-family: system-ui, sans-serif; font-size: .62rem; color: var(--muted); text-transform: none; margin-top: .2rem; letter-spacing: .03em; }
      .w4 { font-weight: 400; } .w5 { font-weight: 500; } .w6 { font-weight: 600; } .w7 { font-weight: 700; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="lede">
        <h1>Panel de fontes — titres</h1>
        <p>
          La police d’origine des titres (<code>Roca One Black</code>) est propriétaire.
          Voici des remplaçantes <strong>libres (OFL)</strong> et auto-hébergeables, rendues avec
          le vrai texte du site. Repère celle qui te plaît, puis dis-moi son nom — je l’applique partout
          et j’ajuste la graisse.
        </p>
        <p>Chaque bloc montre la marque, le titre du hero et la tagline, plus un nuancier de graisses.</p>
        <p>(Le choix actuellement en ligne, <strong>Fredoka</strong>, est visible directement sur l’accueil de la preview.)</p>
      </div>

      {sections.map((section) => (
        <>
          <div class="section-title">{section.title}</div>
          {section.items.map((c) => (
            <div class="card">
              <div class="card__head">
                <span class="card__name">{c.name}</span>
                <span class="card__note">{c.note}</span>
                <span class="card__tag">{c.variable ? 'variable' : 'statique'}</span>
              </div>
              <div class="spec" style={`--ff: ${c.family}, sans-serif`}>
                <div class="brand">petit chardon</div>
                <div class="headline">faites-vous remarquer</div>
                <div class="tagline">graphisme · illustration · rédaction</div>
                <div class="weights">
                  <span class="w4">Aa<small>400</small></span>
                  <span class="w5">Aa<small>500</small></span>
                  <span class="w6">Aa<small>600</small></span>
                  <span class="w7">Aa<small>700</small></span>
                </div>
              </div>
            </div>
          ))}
        </>
      ))}
    </div>
  </body>
</html>
