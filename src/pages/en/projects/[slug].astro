---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectPage from '../../../components/ProjectPage.astro';
import { getDict } from '../../../i18n';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.data.slugs.en },
    props: { project },
  }));
}

const { project } = Astro.props;
const lang = 'en' as const;
const dict = getDict(lang);
const pathname = `/en/projects/${project.data.slugs.en}.html`;
---
<BaseLayout
  lang={lang}
  title={`${project.data.title} | petitchardon`}
  description={project.data.description.en}
  pathname={pathname}
  bodyPage="project-placeholder"
>
  <ProjectPage lang={lang} projectTitle={project.data.title} body={project.data.description.en} />
</BaseLayout>
