---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectPage from '../../../components/ProjectPage.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return projects.map((project, i) => ({
    params: { slug: project.data.slugs.en },
    props: { project, index: i, next: projects[(i + 1) % projects.length] },
  }));
}

const { project, index, next } = Astro.props;
const lang = 'en' as const;
const pathname = `/en/projects/${project.data.slugs.en}.html`;
---
<BaseLayout
  lang={lang}
  title={`${project.data.title} | petitchardon`}
  description={project.data.description.en}
  pathname={pathname}
  bodyPage="project"
>
  <ProjectPage
    lang={lang}
    itemKey={project.data.slugs.fr}
    title={project.data.title}
    tag={project.data.tag}
    cover={project.data.cover}
    index={index}
    nextSlug={next.data.slugs.en}
    nextTitle={next.data.title}
    nextCover={next.data.cover}
  />
</BaseLayout>
