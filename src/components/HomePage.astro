---
import { Image } from 'astro:assets';
import type { Lang } from '../i18n';
import { getDict, projectUrl, asset } from '../i18n';
import GalerieMark from './GalerieMark.astro';
import annePortrait from '../assets/images/anne-portrait.jpg';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);

// Exhibition rooms (salles) — drive the fixed room-index rail.
const rooms = [
  { id: 'hero', label: dict.galerie.room00 },
  { id: 'processus', label: dict.galerie.room01 },
  { id: 'portfolio', label: dict.galerie.room02 },
  { id: 'about', label: dict.galerie.room03 },
  { id: 'contact', label: dict.galerie.room04 },
];
---

{/* Fixed exhibition room index — a quiet vertical rail. Decorative chrome that
   mirrors the document's heading landmarks; hidden from a11y tree, the real
   navigation lives in the header. */}
<nav class="room-index" aria-label={dict.galerie.roomNav} data-room-index>
  <ol>
    {rooms.map((room, i) => (
      <li>
        <a
          class="room-index__link"
          href={`#${room.id}`}
          data-room-link={room.id}
        >
          <span class="room-index__num">{String(i).padStart(2, '0')}</span>
          <span class="room-index__dot" aria-hidden="true"></span>
          <span class="room-index__name">{room.label}</span>
        </a>
      </li>
    ))}
  </ol>
</nav>

{/* Cursor spotlight — purely decorative gallery light that follows the pointer.
   CSS-only resting state (centered, faint) so it never gates first paint. */}
<div class="gallery-spotlight" aria-hidden="true" data-spotlight></div>

<section
  id="hero"
  class="hero salle"
  data-salle="00"
  data-room="hero"
  data-animate="fade-up"
>
  <div class="hero__background" aria-hidden="true"></div>
  <div class="container hero__inner">
    <p class="salle__label" aria-hidden="true">
      <span class="salle__num">{dict.galerie.heroRoom}</span>
      <span class="salle__tick"></span>
      <span class="salle__caption">{dict.galerie.exhibitionLabel}</span>
    </p>
    <div class="hero__copy" data-parallax="0.06">
      <span class="hero__tag">{dict.hero.tag}</span>
      <h1>{dict.hero.title}</h1>
      <p class="hero__location seo-hidden">{dict.hero.location}</p>
      <p class="hero__intro">{dict.hero.intro}</p>
      <p class="hero__services">{dict.hero.services}</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="#portfolio">{dict.hero.ctaProjects}</a>
        <a class="btn btn--ghost" href="#contact">{dict.hero.ctaTalk}</a>
      </div>
    </div>
    <a class="hero__scroll-hint" href="#processus" aria-hidden="true" tabindex="-1">
      <span class="hero__scroll-text">{dict.galerie.heroHint}</span>
      <span class="hero__scroll-line"></span>
    </a>
  </div>
</section>

<section
  id="processus"
  class="process salle"
  data-salle="01"
  data-room="processus"
  data-animate="fade-up"
>
  <div class="container">
    <header class="section-header">
      <p class="salle__label" aria-hidden="true">
        <span class="salle__num">{dict.galerie.room01}</span>
      </p>
      <span class="section-kicker">{dict.process.kicker}</span>
      <h2>{dict.process.title}</h2>
      <p>{dict.process.intro}</p>
    </header>
    <div class="process__grid">
      <article class="process__item glass-surface" data-tilt data-reveal>
        <span class="process__step-num" aria-hidden="true">01</span>
        <figure>
          <GalerieMark name="rencontre" />
        </figure>
        <h3>{dict.process.step1Title}</h3>
        <p>{dict.process.step1Body}</p>
      </article>
      <article class="process__item glass-surface" data-tilt data-reveal>
        <span class="process__step-num" aria-hidden="true">02</span>
        <figure>
          <GalerieMark name="creer" />
        </figure>
        <h3>{dict.process.step2Title}</h3>
        <p>{dict.process.step2Body}</p>
      </article>
      <article class="process__item glass-surface" data-tilt data-reveal>
        <span class="process__step-num" aria-hidden="true">03</span>
        <figure>
          <GalerieMark name="parler" />
        </figure>
        <h3>{dict.process.step3Title}</h3>
        <p>{dict.process.step3Body}</p>
      </article>
      <article class="process__item glass-surface" data-tilt data-reveal>
        <span class="process__step-num" aria-hidden="true">04</span>
        <figure>
          <GalerieMark name="lancer" />
        </figure>
        <h3>{dict.process.step4Title}</h3>
        <p>{dict.process.step4Body}</p>
      </article>
    </div>
    <aside class="process__commitments" data-animate="fade-in" data-reveal>
      <h3>{dict.process.commitTitle}</h3>
      <p>{dict.process.commitIntro}</p>
      <ul class="process__commitments-list">
        <li>{dict.process.commit1}</li>
        <li>{dict.process.commit2}</li>
        <li>{dict.process.commit3}</li>
      </ul>
    </aside>
  </div>
</section>

<section
  id="portfolio"
  class="portfolio salle"
  data-salle="02"
  data-room="portfolio"
  data-animate="fade-in"
>
  <div class="container">
    <header class="section-header">
      <p class="salle__label" aria-hidden="true">
        <span class="salle__num">{dict.galerie.room02}</span>
      </p>
      <span class="section-kicker">{dict.portfolio.kicker}</span>
      <h2>{dict.portfolio.title}</h2>
      <p>{dict.portfolio.intro}</p>
    </header>
    <div class="portfolio__grid">
      <a class="portfolio__card" href={projectUrl(lang, 'lukes-iced-coffees')}>
        <figure>
          <img
            src={asset("assets/galerie/plate-lukes.svg")}
            alt={dict.portfolio.card1Alt}
            width="400"
            height="320"
            loading="lazy"
          />
        </figure>
        <div class="portfolio__content">
          <span class="portfolio__frame-num" aria-hidden="true">01</span>
          <h3>{dict.portfolio.card1Title}</h3>
          <p>{dict.portfolio.card1Body}</p>
          <span class="portfolio__link">{dict.portfolio.viewProject}</span>
        </div>
      </a>
      <a class="portfolio__card" href={projectUrl(lang, 'intelligences-atypiques')}>
        <figure>
          <img
            src={asset("assets/galerie/plate-intelligences.svg")}
            alt={dict.portfolio.card2Alt}
            width="400"
            height="320"
            loading="lazy"
          />
        </figure>
        <div class="portfolio__content">
          <span class="portfolio__frame-num" aria-hidden="true">02</span>
          <h3>{dict.portfolio.card2Title}</h3>
          <p>{dict.portfolio.card2Body}</p>
          <span class="portfolio__link">{dict.portfolio.viewProject}</span>
        </div>
      </a>
      <a class="portfolio__card" href={projectUrl(lang, 'cocobot')}>
        <figure>
          <img
            src={asset("assets/galerie/plate-cocobot.svg")}
            alt={dict.portfolio.card3Alt}
            width="400"
            height="320"
            loading="lazy"
          />
        </figure>
        <div class="portfolio__content">
          <span class="portfolio__frame-num" aria-hidden="true">03</span>
          <h3>{dict.portfolio.card3Title}</h3>
          <p>{dict.portfolio.card3Body}</p>
          <span class="portfolio__link">{dict.portfolio.viewProject}</span>
        </div>
      </a>
      <a class="portfolio__card portfolio__card--cta" href="#contact">
        <div class="portfolio__cta">
          <h3>{dict.portfolio.ctaTitle}</h3>
          <p>{dict.portfolio.ctaBody}</p>
          <span class="btn btn--secondary">{dict.portfolio.ctaButton}</span>
        </div>
      </a>
    </div>
  </div>
</section>

<section
  id="about"
  class="about salle section-divider"
  data-salle="03"
  data-room="about"
  data-animate="fade-in"
>
  <div class="container">
    <header class="section-header">
      <p class="salle__label" aria-hidden="true">
        <span class="salle__num">{dict.galerie.room03}</span>
      </p>
      <h2 class="about__title">{dict.about.title}</h2>
    </header>
    <div class="about__bio">
      <div class="about__photo" data-parallax="0.05">
        <Image src={annePortrait} alt={dict.about.portraitAlt} loading="lazy" />
      </div>
      <div class="about__text">
        <p>{dict.about.p1}</p>
        <p class="about__highlight"><strong>{dict.about.p2Strong}</strong></p>
        <p>{dict.about.p3}</p>
      </div>
    </div>

    <div class="about__carousel">
      <button class="about__nav about__nav--prev" type="button" aria-label={dict.about.carouselPrev} data-about-prev>&lsaquo;</button>
      <div class="about__pillars" data-about-track>
        <article class="about__pillar glass-surface">
          <div class="about__content">
            <h3>{dict.about.pillar1Title}</h3>
            <p><strong>{dict.about.pillar1Strong}</strong></p>
            <p>{dict.about.pillar1Body}</p>
          </div>
          <GalerieMark name="studio" class="about__icon" size={200} />
        </article>
        <article class="about__pillar glass-surface">
          <div class="about__content">
            <h3>{dict.about.pillar2Title}</h3>
            <p><strong>{dict.about.pillar2Strong}</strong></p>
            <p>{dict.about.pillar2Body}</p>
          </div>
          <GalerieMark name="creativite" class="about__icon" size={200} />
        </article>
        <article class="about__pillar glass-surface">
          <div class="about__content">
            <h3>{dict.about.pillar3Title}</h3>
            <p><strong>{dict.about.pillar3Strong}</strong></p>
            <p>{dict.about.pillar3Body}</p>
          </div>
          <GalerieMark name="livrables" class="about__icon" size={200} />
        </article>
      </div>
      <button class="about__nav about__nav--next" type="button" aria-label={dict.about.carouselNext} data-about-next>&rsaquo;</button>
    </div>
  </div>
</section>

<section
  id="contact"
  class="contact salle"
  data-salle="04"
  data-room="contact"
  data-animate="fade-up"
>
  <div class="container contact__inner">
    <div class="contact__intro glass-surface">
      <p class="salle__label" aria-hidden="true">
        <span class="salle__num">{dict.galerie.room04}</span>
      </p>
      <span class="section-kicker">{dict.contact.kicker}</span>
      <h2>{dict.contact.title}</h2>
      <p>{dict.contact.intro}</p>
      <ul class="contact__highlights">
        <li>
          <strong>{dict.contact.labelEmail}</strong>
          <a href="mailto:anne@petitchardon.fr">anne@petitchardon.fr</a>
        </li>
        <li>
          <strong>{dict.contact.labelPhone}</strong>
          <a href="tel:+33627548035">+33&nbsp;6&nbsp;27&nbsp;54&nbsp;80&nbsp;35</a>
        </li>
        <li>
          <strong>{dict.contact.labelLocation}</strong>
          <span>{dict.contact.locationValue}</span>
        </li>
      </ul>
    </div>
    <form
      class="contact__form glass-surface"
      action="https://formsubmit.co/anne@petitchardon.fr"
      method="POST"
      data-form
    >
      <div class="form-field form-field--honeypot" aria-hidden="true">
        <label for="_honey">Leave this field empty</label>
        <input id="_honey" name="_honey" type="text" tabindex="-1" autocomplete="off" />
      </div>
      <div class="form-field">
        <label for="nom">{dict.contact.fieldName}</label>
        <input
          id="nom"
          name="nom"
          type="text"
          autocomplete="name"
          required
          placeholder={dict.contact.placeholderName}
        />
      </div>
      <div class="form-field">
        <label for="email">{dict.contact.fieldEmail}</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder={dict.contact.placeholderEmail}
        />
      </div>
      <div class="form-field">
        <label for="projet">{dict.contact.fieldProject}</label>
        <textarea
          id="projet"
          name="projet"
          rows="4"
          required
          placeholder={dict.contact.placeholderProject}
        ></textarea>
      </div>
      <div class="form-field form-field--checkbox">
        <input id="rgpd" name="rgpd" type="checkbox" value="true" required />
        <label for="rgpd">
          <span>{dict.contact.rgpdLead} </span>
          <a href="#mentions-legales">{dict.contact.rgpdLink}</a>.
        </label>
      </div>
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_subject" value={dict.contact.subject} />
      <input type="hidden" name="_next" value="https://www.petitchardon.fr/" />
      <button class="btn btn--primary" type="submit">{dict.contact.submit}</button>
      <p class="form-feedback" role="status" aria-live="polite" hidden>
        {dict.contact.feedbackSuccess}
      </p>
    </form>
  </div>
</section>

{/* Générique / colophon — film-credits close to the exhibition walk. */}
<section class="colophon" data-room="colophon" data-animate="fade-up">
  <div class="container colophon__inner">
    <p class="colophon__label" aria-hidden="true">{dict.galerie.colophonLabel}</p>
    <h2 class="colophon__title">{dict.galerie.colophonTitle}</h2>
    <dl class="colophon__credits">
      <div class="colophon__credit">
        <dt>{dict.galerie.colophonRole1}</dt>
        <dd>{dict.galerie.colophonRole1Name}</dd>
      </div>
      <div class="colophon__credit">
        <dt>{dict.galerie.colophonRole2}</dt>
        <dd>{dict.galerie.colophonRole2Name}</dd>
      </div>
      <div class="colophon__credit">
        <dt>{dict.galerie.colophonRole3}</dt>
        <dd>{dict.galerie.colophonRole3Name}</dd>
      </div>
    </dl>
    <p class="colophon__close">{dict.galerie.colophonClose}</p>
  </div>
</section>
