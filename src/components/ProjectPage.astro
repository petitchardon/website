---
import type { Lang } from '../i18n';
import { getDict, homeUrl } from '../i18n';

export interface Props {
  lang: Lang;
  projectTitle?: string;
  body?: string;
}

const { lang, projectTitle, body } = Astro.props;
const dict = getDict(lang);
const home = homeUrl(lang);
const headline = projectTitle ?? dict.project.underConstruction;
const text = body ?? dict.project.underConstructionBody;
---

<section class="project-hero" data-animate="fade-up">
  <div class="container project-hero__inner">
    <div class="project-hero__intro glass-surface">
      <p class="breadcrumb">{dict.project.breadcrumb}</p>
      <h1>{headline}</h1>
      <p>{text}</p>
      <div class="project-cta__actions">
        <a class="btn btn--primary" href={`${home}#portfolio`}>
          {dict.project.backToPortfolio}
        </a>
        <a class="btn btn--ghost" href={`${home}#contact`}>
          {dict.project.backToContact}
        </a>
      </div>
    </div>
  </div>
</section>
