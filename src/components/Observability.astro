---
// The bundled <script> at the bottom is always emitted, but observability.ts
// guards itself with a build-time IS_PREVIEW constant — Rollup tree-shakes
// the entire Sentry import on preview builds, so previews ship ~0 KB extra.
//
// The Umami <script> is gated here because it's an external <script src=...>,
// not bundled, so the gate must happen at template time.
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const isPreview = import.meta.env.BASE_URL !== '/';
const showUmami = !isPreview && !!umamiId;
---
{showUmami && (
  <script
    is:inline
    defer
    data-website-id={umamiId}
    data-domains="petitchardon.fr,www.petitchardon.fr"
    src="https://cloud.umami.is/script.js"
  ></script>
)}
<script>
  import { initObservability } from '../lib/observability';
  initObservability();
</script>
