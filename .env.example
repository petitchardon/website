# Public observability config — exposed to the browser.
# Both fields can stay empty during local dev; the Observability component
# is a no-op when neither Umami nor Sentry is configured.

# Umami Cloud — get from cloud.umami.is → site settings → Tracking code
PUBLIC_UMAMI_WEBSITE_ID=

# Sentry browser DSN (region: EU). sentry.io → Settings → Projects → Client Keys
PUBLIC_SENTRY_DSN=

# Optional release SHA for Sentry — set in CI (deploy.yml passes ${GITHUB_SHA})
PUBLIC_RELEASE_SHA=

# Google Search Console verification token (the content="…" of the
# google-site-verification meta tag). Set as a GitHub Actions secret/variable
# so it is injected only into the production build. Leave empty locally.
PUBLIC_GSC_VERIFICATION=

# CI-only secrets, never exposed to the browser. Set as GitHub Actions secrets.
# SENTRY_AUTH_TOKEN=          # used to upload sourcemaps
# SENTRY_ORG=                 # e.g. petitchardon
# SENTRY_PROJECT=             # e.g. petitchardon-website
# UMAMI_API_TOKEN=            # for the observability-sync cron
# BETTER_STACK_API_TOKEN=
# GRAFANA_PROM_USER=
# GRAFANA_PROM_TOKEN=
# GRAFANA_LOKI_USER=
# GRAFANA_LOKI_TOKEN=
