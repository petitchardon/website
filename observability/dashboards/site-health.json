{
  "title": "petitchardon — Site Health",
  "uid": "petitchardon-site-health",
  "tags": ["petitchardon"],
  "timezone": "Europe/Paris",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "avg_over_time(uptime_monitor_up[24h]) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Probe latency p95",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "probe_http_duration_seconds{phase=\"transfer\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SSL days remaining",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "d" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors (24h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sentry_errors_24h"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Web Vitals — LCP / INP / CLS (p75)",
      "description": "Computed from web-vitals events sent to Sentry as measurements.",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.75, sum by (le, name) (rate(sentry_measurement_web_vital_bucket[5m])))",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ]
}
