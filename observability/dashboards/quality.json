{
  "title": "petitchardon — Quality (Lighthouse + Errors)",
  "uid": "petitchardon-quality",
  "tags": ["petitchardon"],
  "timezone": "Europe/Paris",
  "schemaVersion": 39,
  "refresh": "1h",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Lighthouse — Performance",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "lighthouse_score{category=\"performance\"} * 100",
          "legendFormat": "{{url}}"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "short" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Lighthouse — Accessibility / SEO / Best Practices",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "lighthouse_score{category=~\"accessibility|seo|best-practices\"} * 100",
          "legendFormat": "{{category}} — {{url}}"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "short" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Sentry errors per release",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (sha) (sentry_errors_24h)",
          "legendFormat": "{{sha}}"
        }
      ]
    }
  ]
}
